# .env.example
# Локальные настройки сервера. При необходимости скопируйте файл в .env.

HOST=127.0.0.1
PORT=3000
NODE_ENV=development
AUTH_ENCRYPTION_KEY=replace-with-a-long-random-secret-key
SESSION_COOKIE_NAME=todo_session
SESSION_TTL_HOURS=24
VERIFICATION_CODE_TTL_MINUTES=10

EMAIL_REQUIRE_DELIVERY=true
VERIFICATION_CODE_PREVIEW=false
EMAIL_FROM="TaskFlow <your-email@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password

CORS_ALLOWED_ORIGINS=http://localhost:3000
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
LOGIN_ATTEMPT_WINDOW_MS=900000
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_MS=900000
LOGIN_FAILURE_DELAY_MS=300
